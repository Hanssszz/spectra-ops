# Server configuration
PORT=3001
JWT_SECRET=super_secret_jwt_key_change_me

# Database configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/spectra_db?schema=public

# Redis configuration (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS origin
CORS_ORIGIN=http://localhost:3000

# Cloudinary credentials (for incident photo upload)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email service credentials (for incident notification alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
# Comma-separated list of supervisor/manager email addresses
ALERT_EMAIL_RECIPIENTS=supervisor@example.com,manager@example.com
